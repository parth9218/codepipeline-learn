{
  "name": "hello-api-infra",
  "version": "1.0.0",
  "description": "CDK infrastructure for Hello API — API Gateway + Lambda",
  "scripts": {
    "build":  "tsc",
    "watch":  "tsc -w",
    "test":   "jest --forceExit",
    "cdk":    "cdk",
    "synth":  "cdk synth",
    "deploy": "cdk deploy"
  },
  "devDependencies": {
    "@types/jest":    "^29.5.12",
    "@types/node":    "^20.12.7",
    "aws-cdk":        "^2.139.0",
    "jest":           "^29.7.0",
    "ts-jest":        "^29.1.2",
    "ts-node":        "^10.9.2",
    "typescript":     "^5.4.5"
  },
  "dependencies": {
    "aws-cdk-lib":  "^2.139.0",
    "constructs":   "^10.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": ["<rootDir>/test"],
    "testMatch": ["**/*.test.ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {}]
    }
  }
}
