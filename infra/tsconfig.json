{
  "compilerOptions": {
    "target":                           "ES2020",
    "module":                           "commonjs",
    "lib":                              ["ES2020"],
    "declaration":                      true,
    "strict":                           true,
    "noImplicitAny":                    true,
    "strictNullChecks":                 true,
    "noImplicitThis":                   true,
    "alwaysStrict":                     true,
    "esModuleInterop":                  true,
    "skipLibCheck":                     true,
    "forceConsistentCasingInFileNames": true,
    "outDir":                           "dist",
    "rootDir":                          ".",
    "experimentalDecorators":           true
  },
  "include":  ["bin/**/*", "lib/**/*", "test/**/*"],
  "exclude":  ["node_modules", "dist", "cdk.out"]
}
